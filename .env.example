# .env.example
# Copy this file to .env and fill in your own values.

# ================================================================
# DJANGO SETTINGS
# ================================================================
SECRET_KEY=your-super-secret-key-here
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1,.vercel.app,.railway.app,.herokuapp.com
DJANGO_SETTINGS_MODULE=financas.settings.development

# ================================================================
# DATABASE SETTINGS
# ================================================================
# PostgreSQL (Produção)
POSTGRES_DB=financas_db
POSTGRES_USER=financas_user
POSTGRES_PASSWORD=your_postgres_password
DATABASE_URL=postgresql://${POSTGRES_USER}:${POSTGRES_PASSWORD}@localhost:5432/${POSTGRES_DB}

# SQLite (Desenvolvimento - fallback)
SQLITE_URL=sqlite:///db.sqlite3

# ================================================================
# EMAIL SETTINGS (Brevo SMTP)
# ================================================================
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp-relay.brevo.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=your_brevo_email_address
EMAIL_HOST_PASSWORD=your_brevo_smtp_key
DEFAULT_FROM_EMAIL=your_default_from_email@example.com
SERVER_EMAIL=your_default_from_email@example.com

# ================================================================
# EXTERNAL SERVICES
# ================================================================
# Redis (Cache)
REDIS_URL=redis://localhost:6379/1

# Sentry (Error Tracking)
SENTRY_DSN=your_sentry_dsn_here

# ================================================================
# APPLICATION SPECIFIC
# ================================================================
BACKUP_ENABLED=False
BACKUP_DIR=./backups